# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/frame_a

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Server ──
PORT=3000
NODE_ENV=development

# ── Authentication ──
JWT_SECRET=dev-secret-change-in-production-minimum-64-chars-xxxxxxxxxxxxxxxx
BCRYPT_SALT_ROUNDS=12

# ── Federation ──
HOMESERVER_DOMAIN=localhost:3000
FEDERATION_SIGNING_KEY=dev-signing-key-generate-ed25519-for-production
FEDERATION_PEERS=localhost:3001

# ── CORS ──
CORS_ORIGINS=http://localhost:5173
